{
  "name": "@versedhand/plane-mcp",
  "version": "1.0.0",
  "description": "Lean MCP server for Plane CE — direct PostgreSQL access for AI agents. 8 tools, ~1600 token schema footprint.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "plane-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "plane",
    "plane-ce",
    "model-context-protocol",
    "ai-agents",
    "project-management",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/versedhand/plane-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Isaac Robinson",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "pg": "^8.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  }
}
