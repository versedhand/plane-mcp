# Plane CE PostgreSQL connection (reads)
PLANE_PERSONAL_DB_HOST=127.0.0.1
PLANE_PERSONAL_DB_PORT=5432
PLANE_PERSONAL_DB_USER=plane_mcp
PLANE_PERSONAL_DB_PASSWORD=
PLANE_PERSONAL_DB_NAME=plane
PLANE_PERSONAL_WORKSPACE_SLUG=personal

# Plane CE REST API (mutations — optional, falls back to SQL)
# When configured, create/update/complete operations go through the API
# so Plane's Django app triggers notifications, activity logs, webhooks.
PLANE_PERSONAL_API_URL=https://plane.example.com
PLANE_PERSONAL_API_KEY=plane_api_...

# Second instance (optional)
# PLANE_NTS_DB_HOST=127.0.0.1
# PLANE_NTS_DB_PORT=5433
# PLANE_NTS_DB_USER=plane_mcp
# PLANE_NTS_DB_PASSWORD=
# PLANE_NTS_DB_NAME=plane
# PLANE_NTS_WORKSPACE_SLUG=nts
# PLANE_NTS_API_URL=https://plane-nts.example.com
# PLANE_NTS_API_KEY=plane_api_...

# LifeDB (for recurrence engine)
# LIFEDB_URL=postgresql://user:pass@host:5432/lifedb

# Legacy single-instance format (deprecated, maps to 'personal')
# PLANE_DB_HOST=127.0.0.1
# PLANE_DB_PORT=5432
# PLANE_DB_USER=plane_mcp
# PLANE_DB_PASSWORD=
# PLANE_DB_NAME=plane
# PLANE_WORKSPACE_SLUG=personal
