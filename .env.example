# Plane CE PostgreSQL connection
PLANE_DB_HOST=127.0.0.1        # Direct or via SSH tunnel
PLANE_DB_PORT=5432              # Default PG port (use 15432 for SSH tunnel)
PLANE_DB_USER=plane_mcp         # Dedicated MCP role (not the default 'plane' user)
PLANE_DB_PASSWORD=               # Set during PostgreSQL role creation
PLANE_DB_NAME=plane
PLANE_WORKSPACE_SLUG=personal   # Workspace slug for scoping queries
